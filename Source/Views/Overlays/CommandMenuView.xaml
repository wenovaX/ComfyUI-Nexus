<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:loc="clr-namespace:ComfyUI_Nexus.Localization"
			 x:Class="ComfyUI_Nexus.Views.Overlays.CommandMenuView"
			 x:Name="CommandMenuRoot"
			 IsVisible="False"
			 Opacity="0"
			 InputTransparent="True">
	<Border x:Name="CommandMenuBorder"
			BackgroundColor="{StaticResource CommandMenuSurfaceColor}"
			Stroke="{StaticResource CommandMenuStrokeColor}"
			StrokeThickness="1"
			Padding="8"
			WidthRequest="160"
			HorizontalOptions="Start"
			VerticalOptions="Start">
		<Border.StrokeShape>
			<RoundRectangle CornerRadius="10" />
		</Border.StrokeShape>
		<Border.Resources>
			<Style x:Key="MenuButtonStyle" TargetType="Button">
				<Setter Property="BackgroundColor" Value="Transparent" />
				<Setter Property="TextColor" Value="{StaticResource CommandMenuTextColor}" />
				<Setter Property="FontSize" Value="12" />
				<Setter Property="FontAttributes" Value="Bold" />
				<Setter Property="HeightRequest" Value="42" />
				<Setter Property="Padding" Value="14,0" />
				<Setter Property="CornerRadius" Value="12" />
				<Setter Property="HorizontalOptions" Value="Fill" />
				<Setter Property="VisualStateManager.VisualStateGroups">
					<VisualStateGroupList>
						<VisualStateGroup x:Name="CommonStates">
							<VisualState x:Name="Normal" />
							<VisualState x:Name="PointerOver">
								<VisualState.Setters>
									<Setter Property="BackgroundColor" Value="{StaticResource CommandMenuHoverSurfaceColor}" />
									<Setter Property="TextColor" Value="{StaticResource CommandMenuHoverTextColor}" />
								</VisualState.Setters>
							</VisualState>
							<VisualState x:Name="Pressed">
								<VisualState.Setters>
									<Setter Property="BackgroundColor" Value="{StaticResource CommandMenuPressedSurfaceColor}" />
								</VisualState.Setters>
							</VisualState>
						</VisualStateGroup>
					</VisualStateGroupList>
				</Setter>
			</Style>
			<Style x:Key="MenuSeparatorStyle" TargetType="BoxView">
				<Setter Property="HeightRequest" Value="1" />
				<Setter Property="BackgroundColor" Value="{StaticResource CommandMenuSeparatorColor}" />
				<Setter Property="Margin" Value="12,5" />
				<Setter Property="Opacity" Value="0.75" />
			</Style>
		</Border.Resources>
		<Grid>
			<Border BackgroundColor="Transparent"
					StrokeThickness="0"
					Padding="0">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="12" />
				</Border.StrokeShape>
				<VerticalStackLayout Spacing="3">
					<Button Text="{loc:Loc common.restart_server}"
							SemanticProperties.Description="{loc:Loc common.restart_server}"
							SemanticProperties.Hint="{loc:Loc views.overlays.command_menu_view.restart_server_help}"
							Style="{StaticResource MenuButtonStyle}"
							Command="{Binding RestartServerCommand, Source={x:Reference CommandMenuRoot}}" />
					<BoxView Style="{StaticResource MenuSeparatorStyle}" />
					<Button Text="{loc:Loc command.menu.settings}"
							SemanticProperties.Description="{loc:Loc command.menu.settings}"
							SemanticProperties.Hint="{loc:Loc views.overlays.command_menu_view.settings_help}"
							Style="{StaticResource MenuButtonStyle}"
							Command="{Binding SettingsCommand, Source={x:Reference CommandMenuRoot}}" />
					<Button Text="{loc:Loc common.help}"
							SemanticProperties.Description="{loc:Loc common.help}"
							SemanticProperties.Hint="{loc:Loc views.overlays.command_menu_view.help_help}"
							Style="{StaticResource MenuButtonStyle}"
							Command="{Binding HelpCommand, Source={x:Reference CommandMenuRoot}}" />
					<Button Text="{loc:Loc command.menu.about}"
							SemanticProperties.Description="{loc:Loc command.menu.about}"
							SemanticProperties.Hint="{loc:Loc views.overlays.command_menu_view.about_help}"
							Style="{StaticResource MenuButtonStyle}"
							Command="{Binding AboutCommand, Source={x:Reference CommandMenuRoot}}" />
					<BoxView Style="{StaticResource MenuSeparatorStyle}" />
					<Button Text="{loc:Loc command.menu.exit}"
							SemanticProperties.Description="{loc:Loc command.menu.exit}"
							SemanticProperties.Hint="{loc:Loc views.overlays.command_menu_view.exit_help}"
							Style="{StaticResource MenuButtonStyle}"
							Command="{Binding ExitCommand, Source={x:Reference CommandMenuRoot}}" />
				</VerticalStackLayout>
			</Border>
		</Grid>
	</Border>
</ContentView>
