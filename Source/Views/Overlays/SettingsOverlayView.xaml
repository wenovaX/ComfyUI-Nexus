		<Style x:Key="SettingsNavButtonStyle" TargetType="Button">
			<Setter Property="BackgroundColor" Value="Transparent" />
			<Setter Property="TextColor" Value="#a9cce2" />
			<Setter Property="FontSize" Value="12" />
			<Setter Property="FontAttributes" Value="Bold" />
			<Setter Property="HeightRequest" Value="38" />
			<Setter Property="CornerRadius" Value="12" />
			<Setter Property="Padding" Value="14,0" />
			<Setter Property="HorizontalOptions" Value="Fill" />
			<Setter Property="VisualStateManager.VisualStateGroups">
				<VisualStateGroupList>
					<VisualStateGroup x:Name="CommonStates">
						<VisualState x:Name="Normal" />
						<VisualState x:Name="PointerOver">
							<VisualState.Setters>
								<Setter Property="BackgroundColor" Value="#1431d8ff" />
								<Setter Property="TextColor" Value="#f4feff" />
							</VisualState.Setters>
						</VisualState>
						<VisualState x:Name="Disabled">
							<VisualState.Setters>
								<Setter Property="BackgroundColor" Value="#0617222f" />
								<Setter Property="TextColor" Value="#55748c" />
							</VisualState.Setters>
						</VisualState>
					</VisualStateGroup>
				</VisualStateGroupList>
			</Setter>
		</Style>
		<Style x:Key="SettingsSectionTitleStyle" TargetType="Label">
			<Setter Property="TextColor" Value="#f4feff" />
			<Setter Property="FontSize" Value="17" />
			<Setter Property="FontAttributes" Value="Bold" />
			<Setter Property="Margin" Value="0,8,0,0" />
		</Style>
		<Style x:Key="SettingsKeyStyle" TargetType="Label">
			<Setter Property="TextColor" Value="#7fa0b8" />
			<Setter Property="FontSize" Value="10" />
			<Setter Property="FontAttributes" Value="Bold" />
		</Style>
		<Style x:Key="SettingsValueStyle" TargetType="Label">
			<Setter Property="TextColor" Value="#e8f8ff" />
			<Setter Property="FontSize" Value="12" />
