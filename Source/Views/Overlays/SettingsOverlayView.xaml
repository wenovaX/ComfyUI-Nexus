<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
	xmlns:loc="clr-namespace:ComfyUI_Nexus.Localization"
			 x:Class="ComfyUI_Nexus.Views.Overlays.SettingsOverlayView"
			 IsVisible="False"
			 Opacity="0"
			 InputTransparent="True">
	<Grid BackgroundColor="{StaticResource SettingsBackdropColor}"
		  Padding="34">
		<Grid x:Name="SettingsPanelHost"
			  HorizontalOptions="Center"
			  VerticalOptions="Center">
			<Border x:Name="SettingsPanelBorder"
					WidthRequest="980"
					HeightRequest="680"
					HorizontalOptions="Center"
					VerticalOptions="Center"
					BackgroundColor="{StaticResource SettingsPanelColor}"
					Stroke="{StaticResource SettingsPanelStrokeColor}"
					StrokeThickness="1"
					Padding="0">
			<Border.StrokeShape>
				<RoundRectangle CornerRadius="26" />
			</Border.StrokeShape>
			<Border.Shadow>
				<Shadow x:Name="SettingsPanelGlow" Brush="{StaticResource SettingsAccentColor}" Opacity="0" Radius="34" Offset="0,12" />
			</Border.Shadow>

			<Grid RowDefinitions="Auto,Auto,*,Auto">
				<Grid Grid.Row="0"
					  ColumnDefinitions="*,Auto"
					  Padding="28,24,24,18">
					<VerticalStackLayout Spacing="4">
						<Label Text="{loc:Loc views.overlays.settings_overlay_view.nexus_settings}"
							   TextColor="{StaticResource SettingsTitleColor}"
							   FontSize="20"
							   FontAttributes="Bold" />
						<Label Text="{loc:Loc views.overlays.settings_overlay_view.comfyui_runtime_toolchain_server_launch_and_maintenance}"
							   TextColor="{StaticResource SettingsSubtitleColor}"
							   FontSize="12" />
					</VerticalStackLayout>
					<Button Grid.Column="1"
							Text="{loc:Loc common.close}"
							Clicked="OnCloseClicked"
							Style="{StaticResource SettingsHeaderButtonStyle}" />
				</Grid>

				<VerticalStackLayout Grid.Row="1"
									 Margin="28,0,24,16"
									 Spacing="10">
					<Border x:Name="RestartRequiredBanner"
							IsVisible="False"
							BackgroundColor="#1Fffaa00"
							Stroke="#66ffaa00"
							StrokeThickness="1"
							Padding="14,10">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="14" />
						</Border.StrokeShape>
						<Grid ColumnDefinitions="*,Auto"
							  RowDefinitions="Auto,Auto"
							  ColumnSpacing="14"
							  RowSpacing="3">
							<Label Text="{loc:Loc views.overlays.settings_overlay_view.restart_required_to_apply_pending_changes}"
								   TextColor="#ffe6b0"
								   FontSize="12"
								   FontAttributes="Bold"
								   VerticalOptions="Center" />
							<Label x:Name="RestartReasonLabel"
								   Grid.Row="1"
								   Grid.Column="0"
								   TextColor="#d8b879"
								   FontSize="10" />
							<Button Grid.Column="1"
									Grid.RowSpan="2"
									x:Name="RestartServerButton"
									Text="{loc:Loc common.restart_server}"
									Clicked="OnRestartClicked"
									Style="{StaticResource SettingsRestartButtonStyle}" />
						</Grid>
					</Border>
					<Border x:Name="PendingBootChecklistPanel"
							IsVisible="False"
							BackgroundColor="#1A31d8ff"
							Stroke="#3831d8ff"
							StrokeThickness="1"
							Padding="14,8">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="14" />
						</Border.StrokeShape>
						<Grid ColumnDefinitions="Auto,*,Auto,Auto"
							  RowDefinitions="Auto,Auto"
							  ColumnSpacing="12"
							  RowSpacing="7">
							<Label Text="{loc:Loc views.overlays.settings_overlay_view.next_boot_checklist}"
								   TextColor="#bfefff"
								   FontSize="11"
								   FontAttributes="Bold"
								   VerticalOptions="Center" />
							<Label x:Name="PendingBootChecklistPreviewLabel"
								   Grid.Column="1"
								   TextColor="#6f8795"
								   FontSize="10"
								   HorizontalTextAlignment="End"
								   VerticalOptions="Center"
								   LineBreakMode="TailTruncation" />
							<Label x:Name="PendingBootChecklistSummaryLabel"
								   Grid.Column="2"
								   TextColor="#8fdcff"
								   FontSize="10"
								   FontAttributes="Bold"
								   HorizontalTextAlignment="End"
								   VerticalOptions="Center" />
							<Button x:Name="PendingBootChecklistToggleButton"
									Grid.Column="3"
									Text="{loc:Loc views.overlays.settings_overlay_view.expand}"
									Clicked="OnPendingBootChecklistToggleClicked"
									Style="{StaticResource SettingsMicroButtonStyle}" />
							<VerticalStackLayout x:Name="PendingBootTaskList"
												 Grid.Row="1"
												 Grid.ColumnSpan="4"
												 Spacing="6" />
						</Grid>
					</Border>
				</VerticalStackLayout>

				<Grid Grid.Row="2"
					  ColumnDefinitions="210,*"
					  Padding="22,0,22,0"
					  ColumnSpacing="18">
					<Border Grid.Column="0"
							BackgroundColor="{StaticResource SettingsNavPanelColor}"
							Stroke="{StaticResource SettingsNavPanelStrokeColor}"
							StrokeThickness="1"
							Padding="10">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="20" />
						</Border.StrokeShape>
						<VerticalStackLayout Spacing="6">
							<Button Text="Nexus" Style="{StaticResource SettingsNavButtonStyle}" Clicked="OnNexusClicked" />
							<Button Text="ComfyUI" Style="{StaticResource SettingsNavButtonStyle}" Clicked="OnComfyClicked" />
							<Button Text="{loc:Loc views.overlays.settings_overlay_view.tools}" Style="{StaticResource SettingsNavButtonStyle}" Clicked="OnToolsClicked" />
							<Button Text="{loc:Loc views.overlays.settings_overlay_view.server}" Style="{StaticResource SettingsNavButtonStyle}" Clicked="OnServerClicked" />
							<Button Text="{loc:Loc views.overlays.settings_overlay_view.maintenance}" Style="{StaticResource SettingsNavButtonStyle}" Clicked="OnMaintenanceClicked" />
							<Button Text="{loc:Loc views.overlays.settings_overlay_view.extensions}" Style="{StaticResource SettingsNavButtonStyle}" Clicked="OnExtensionsClicked" />
						</VerticalStackLayout>
					</Border>

					<Border Grid.Column="1"
							BackgroundColor="{StaticResource SettingsContentPanelColor}"
							Stroke="{StaticResource SettingsContentPanelStrokeColor}"
							StrokeThickness="1"
							Padding="0">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="20" />
						</Border.StrokeShape>
						<ScrollView x:Name="SettingsScrollView">
							<VerticalStackLayout Padding="24"
												 Spacing="16">
								<VerticalStackLayout x:Name="NexusSection" Spacing="10">
									<Label Text="Nexus" Style="{StaticResource SettingsSectionTitleStyle}" />
									<Border Style="{StaticResource SettingsCardStyle}">
										<Grid RowDefinitions="Auto,Auto,Auto"
											  RowSpacing="10">
											<Label Text="{loc:Loc views.overlays.settings_overlay_view.language}" Style="{StaticResource SettingsKeyStyle}" />
											<Label Grid.Row="1"
												   Text="{loc:Loc views.overlays.settings_overlay_view.choose_the_language_used_by_the_nexus_shell}"
												   Style="{StaticResource SettingsHintStyle}" />
											<Picker x:Name="LanguagePicker"
													Grid.Row="2"
													SelectedIndexChanged="OnLanguagePickerSelectedIndexChanged"
													Title="{loc:Loc views.overlays.settings_overlay_view.select_language}"
													TextColor="#f4feff"
													TitleColor="#6f8ca5"
													BackgroundColor="#152334" />
										</Grid>
									</Border>
									<Border Style="{StaticResource SettingsCardStyle}">
										<Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
											<Label Text="ComfyUI-Nexus" Style="{StaticResource SettingsKeyStyle}" />
											<Label x:Name="VersionValueLabel" Grid.Row="1" Style="{StaticResource SettingsValueStyle}" />
											<Label x:Name="ServerUrlValueLabel" Grid.Row="2" Style="{StaticResource SettingsValueStyle}" />
											<Label x:Name="SettingsStateValueLabel" Grid.Row="3" Style="{StaticResource SettingsValueStyle}" />
										</Grid>
									</Border>
								</VerticalStackLayout>

								<VerticalStackLayout x:Name="ComfySection" Spacing="10">
									<Label Text="ComfyUI" Style="{StaticResource SettingsSectionTitleStyle}" />
									<Border Style="{StaticResource SettingsCardStyle}">
										<Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">
											<Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
												<VerticalStackLayout Spacing="5">
													<Label Text="{loc:Loc views.overlays.settings_overlay_view.runtime_source}" Style="{StaticResource SettingsKeyStyle}" />
													<Label x:Name="InstallModeValueLabel" Style="{StaticResource SettingsValueStyle}" />
												</VerticalStackLayout>
												<Button x:Name="UseLocalRuntimeButton"
														Grid.Column="1"
														Text="{loc:Loc views.overlays.settings_overlay_view.local}"
														Clicked="OnUseLocalRuntimeClicked"
														Style="{StaticResource SettingsChipButtonStyle}" />
												<Button x:Name="UseCustomComfyButton"
														Grid.Column="2"
														Text="{loc:Loc views.overlays.settings_overlay_view.custom}"
														Clicked="OnSelectComfyPathClicked"
														Style="{StaticResource SettingsChipButtonStyle}" />
											</Grid>
											<Border Grid.Row="1"
													Style="{StaticResource SettingsInsetBoxStyle}"
													StrokeThickness="0"
													Padding="12,9">
												<Label x:Name="ComfyPathValueLabel"
													   Style="{StaticResource SettingsValueStyle}"
													   LineBreakMode="TailTruncation" />
											</Border>
											<Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,Auto,*" ColumnSpacing="8">
												<Button x:Name="OpenComfyFolderButton"
														Text="{loc:Loc views.overlays.settings_overlay_view.open_folder}"
														Clicked="OnOpenComfyFolderClicked"
														Style="{StaticResource SettingsSecondaryButtonStyle}" />
												<Button x:Name="ChangeComfyPathButton"
														Grid.Column="1"
														Text="{loc:Loc views.overlays.settings_overlay_view.change_path}"
														Clicked="OnSelectComfyPathClicked"
														Style="{StaticResource SettingsSecondaryButtonStyle}" />
												<Button x:Name="CheckComfyUpdatesButton"
														Grid.Column="2"
														Text="{loc:Loc views.overlays.settings_overlay_view.check_updates}"
														Clicked="OnCheckComfyUpdatesClicked"
														Style="{StaticResource SettingsSecondaryButtonStyle}" />
												<Button x:Name="ComfyApplyUpdateButton"
														Grid.Column="3"
														Text="{loc:Loc views.overlays.settings_overlay_view.update_now}"
														IsVisible="False"
														IsEnabled="False"
														Clicked="OnApplyComfyUpdateClicked"
														Style="{StaticResource SettingsRestartButtonStyle}" />
											</Grid>
											<Label x:Name="ComfyUpdateValueLabel"
												   Grid.Row="3"
												   Text="{loc:Loc views.overlays.settings_overlay_view.check_repository_status_to_see_whether_this_comfyui_chec}"
												   Style="{StaticResource SettingsHintStyle}" />
										</Grid>
									</Border>
									<Border Style="{StaticResource SettingsCardStyle}">
										<VerticalStackLayout Spacing="11">
											<Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
												<VerticalStackLayout Spacing="4">
													<Label Text="{loc:Loc settings.model_libraries.title}" Style="{StaticResource SettingsKeyStyle}" />
													<Label Text="{loc:Loc settings.model_libraries.description}"
														   Style="{StaticResource SettingsHintStyle}" />
												</VerticalStackLayout>
												<Button Grid.Column="1"
														Text="{loc:Loc settings.model_libraries.add_library}"
														Clicked="OnAddModelLibraryClicked"
														Style="{StaticResource SettingsSecondaryButtonStyle}" />
												<Button x:Name="SyncModelLibraryStructureButton"
														Grid.Column="2"
														Text="{loc:Loc settings.model_libraries.sync_structure}"
														Clicked="OnSyncModelLibraryStructureClicked"
														Style="{StaticResource SettingsSecondaryButtonStyle}" />
											</Grid>
											<VerticalStackLayout x:Name="ModelLibrariesList" Spacing="8" />
											<Grid RowDefinitions="Auto,Auto,Auto"
												  RowSpacing="8"
												  BackgroundColor="#0Dffffff"
												  Padding="12,10">
												<Grid ColumnDefinitions="*,Auto,Auto"
													  ColumnSpacing="8">
													<VerticalStackLayout Spacing="3">
														<Label Text="{loc:Loc settings.model_duplicates.title}"
															   Style="{StaticResource SettingsKeyStyle}" />
														<Label Text="{loc:Loc settings.model_duplicates.description}"
															   Style="{StaticResource SettingsHintStyle}" />
													</VerticalStackLayout>
													<Button x:Name="ScanModelDuplicatesButton"
															Grid.Column="1"
															Text="{loc:Loc settings.model_duplicates.scan}"
															Clicked="OnScanModelDuplicatesClicked"
															Style="{StaticResource SettingsSecondaryButtonStyle}" />
													<Button x:Name="OpenModelDuplicateReportButton"
															Grid.Column="2"
															Text="{loc:Loc settings.model_duplicates.open_report}"
															Clicked="OnOpenModelDuplicateReportClicked"
															Style="{StaticResource SettingsTextButtonStyle}" />
												</Grid>
												<Label x:Name="ModelDuplicateStatusLabel"
													   Grid.Row="1"
													   Text="{loc:Loc settings.model_duplicates.ready}"
													   Style="{StaticResource SettingsHintStyle}" />
												<Grid Grid.Row="2"
													  ColumnDefinitions="Auto,Auto,Auto,*"
													  ColumnSpacing="7">
													<Button x:Name="OpenDuplicateLocation1Button"
															Text="{loc:Loc settings.model_duplicates.open_location_1}"
															Clicked="OnOpenDuplicateLocation1Clicked"
															Style="{StaticResource SettingsTextButtonStyle}" />
													<Button x:Name="OpenDuplicateLocation2Button"
															Grid.Column="1"
															Text="{loc:Loc settings.model_duplicates.open_location_2}"
															Clicked="OnOpenDuplicateLocation2Clicked"
															Style="{StaticResource SettingsTextButtonStyle}" />
													<Button x:Name="NextModelDuplicateButton"
															Grid.Column="2"
															Text="{loc:Loc settings.model_duplicates.next}"
															Clicked="OnNextModelDuplicateClicked"
															Style="{StaticResource SettingsTextButtonStyle}" />
												</Grid>
											</Grid>
											<Label x:Name="ModelLibrariesStatusLabel"
												   IsVisible="False"
												   Style="{StaticResource SettingsHintStyle}" />
											<Label Text="{loc:Loc settings.model_libraries.restart_hint}"
												   Style="{StaticResource SettingsHintStyle}" />
										</VerticalStackLayout>
									</Border>
								</VerticalStackLayout>

								<VerticalStackLayout x:Name="ToolsSection" Spacing="10">
									<Label Text="{loc:Loc views.overlays.settings_overlay_view.tools}" Style="{StaticResource SettingsSectionTitleStyle}" />
									<Border Style="{StaticResource SettingsCardStyle}">
										<Grid RowDefinitions="Auto" RowSpacing="16">
											<VerticalStackLayout Spacing="8">
												<Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
													<VerticalStackLayout Spacing="5">
														<Label Text="Git" Style="{StaticResource SettingsKeyStyle}" />
														<Label x:Name="GitVersionValueLabel" Style="{StaticResource SettingsValueStyle}" />
													</VerticalStackLayout>
													<Button x:Name="UseSystemGitButton" Grid.Column="1" Text="{loc:Loc views.overlays.settings_overlay_view.system}" Clicked="OnUseSystemGitClicked" Style="{StaticResource SettingsChipButtonStyle}" />
													<Button x:Name="UseBuiltInGitButton" Grid.Column="2" Text="{loc:Loc views.overlays.settings_overlay_view.built_in}" Clicked="OnUseBuiltInGitClicked" Style="{StaticResource SettingsChipButtonStyle}" />
													<Button x:Name="UseCustomGitButton" Grid.Column="3" Text="{loc:Loc views.overlays.settings_overlay_view.custom}" Clicked="OnSelectCustomGitClicked" Style="{StaticResource SettingsChipButtonStyle}" />
												</Grid>
												<Label x:Name="GitPathValueLabel" Style="{StaticResource SettingsValueStyle}" LineBreakMode="TailTruncation" />
											</VerticalStackLayout>
										</Grid>
									</Border>
									<Border Style="{StaticResource SettingsCardStyle}">
										<Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
											  RowSpacing="13">
											<Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
												<VerticalStackLayout Spacing="5">
													<Label Text="Python" Style="{StaticResource SettingsKeyStyle}" />
													<Label x:Name="PythonVersionValueLabel" Style="{StaticResource SettingsValueStyle}" />
												</VerticalStackLayout>
												<Button x:Name="UseSystemPythonButton" Grid.Column="1" Text="{loc:Loc views.overlays.settings_overlay_view.system}" Clicked="OnUseSystemPythonClicked" Style="{StaticResource SettingsChipButtonStyle}" />
												<Button x:Name="UseBuiltInPythonButton" Grid.Column="2" Text="{loc:Loc views.overlays.settings_overlay_view.built_in}" Clicked="OnUseBuiltInPythonClicked" Style="{StaticResource SettingsChipButtonStyle}" />
												<Button x:Name="UseCustomPythonButton" Grid.Column="3" Text="{loc:Loc views.overlays.settings_overlay_view.custom}" Clicked="OnSelectCustomPythonClicked" Style="{StaticResource SettingsChipButtonStyle}" />
											</Grid>
											<Label x:Name="PythonPathValueLabel"
												   Grid.Row="1"
												   Style="{StaticResource SettingsValueStyle}"
												   LineBreakMode="TailTruncation" />
											<BoxView Grid.Row="2" HeightRequest="1" BackgroundColor="#20344a" Opacity="0.75" />
											<Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
												<VerticalStackLayout Spacing="5">
													<Label Text="{loc:Loc views.overlays.settings_overlay_view.runtime_mode}" Style="{StaticResource SettingsKeyStyle}" />
													<Label x:Name="PythonRuntimeSummaryLabel"
														   Style="{StaticResource SettingsValueStyle}" />
												</VerticalStackLayout>
												<Button x:Name="UseVenvButton"
														Grid.Column="1"
														Text="VENV"
														Clicked="OnUseVenvClicked"
														Style="{StaticResource SettingsChipButtonStyle}" />
												<Button x:Name="UseConfiguredPythonButton"
														Grid.Column="2"
														Text="DIRECT"
														Clicked="OnUseConfiguredPythonClicked"
														Style="{StaticResource SettingsChipButtonStyle}" />
											</Grid>
											<BoxView Grid.Row="4" HeightRequest="1" BackgroundColor="#20344a" Opacity="0.75" />
											<Grid Grid.Row="5" ColumnDefinitions="*,Auto"
												  ColumnSpacing="8">
												<VerticalStackLayout Spacing="5">
													<Label Text="{loc:Loc views.overlays.settings_overlay_view.virtual_environment}" Style="{StaticResource SettingsKeyStyle}" />
													<Label x:Name="VenvStateValueLabel" Style="{StaticResource SettingsValueStyle}" />
												</VerticalStackLayout>
												<HorizontalStackLayout x:Name="VenvActionGroup"
														Grid.Column="1"
														Spacing="8"
														HorizontalOptions="End"
														VerticalOptions="Center">
													<Button x:Name="CreateVenvButton"
															Text="{loc:Loc views.overlays.settings_overlay_view.create}"
															Clicked="OnCreateVenvClicked"
															Style="{StaticResource SettingsSecondaryButtonStyle}" />
													<Button x:Name="ResetVenvButton"
															Text="{loc:Loc views.overlays.settings_overlay_view.reset}"
															Clicked="OnResetVenvClicked"
															Style="{StaticResource SettingsRestartButtonStyle}" />
													<Button x:Name="DeleteVenvButton"
															Text="{loc:Loc views.overlays.settings_overlay_view.delete}"
															Clicked="OnDeleteVenvClicked"
															Style="{StaticResource SettingsSecondaryButtonStyle}" />
												</HorizontalStackLayout>
											</Grid>
											<Label x:Name="VenvPathValueLabel"
												   Grid.Row="6"
												   Style="{StaticResource SettingsValueStyle}"
												   LineBreakMode="TailTruncation" />
											<Label x:Name="VenvDetailValueLabel"
												   Grid.Row="7"
												   Style="{StaticResource SettingsHintStyle}" />
											<BoxView Grid.Row="8" HeightRequest="1" BackgroundColor="#20344a" Opacity="0.75" />
											<Grid Grid.Row="9" ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">
												<VerticalStackLayout Spacing="5">
													<Label Text="{loc:Loc settings.pip_cache.title}" Style="{StaticResource SettingsKeyStyle}" />
													<Label Text="{loc:Loc settings.pip_cache.description}"
														   Style="{StaticResource SettingsValueStyle}" />
												</VerticalStackLayout>
												<Button x:Name="PipCacheUsePipDefaultButton"
														Grid.Column="1"
														Text="{loc:Loc settings.pip_cache.use_pip_default}"
														Clicked="OnUsePipDefaultCacheClicked"
														Style="{StaticResource SettingsBackupOptionButtonStyle}" />
												<Button x:Name="PipCacheUseDefaultButton"
														Grid.Column="2"
														Text="{loc:Loc settings.pip_cache.use_default}"
														Clicked="OnUseDefaultPipCacheClicked"
														Style="{StaticResource SettingsBackupOptionButtonStyle}" />
												<Button x:Name="PipCacheChangeButton"
														Grid.Column="3"
														Text="{loc:Loc settings.pip_cache.change}"
														Clicked="OnChangePipCacheClicked"
														Style="{StaticResource SettingsBackupOptionButtonStyle}" />
												<Button x:Name="PipCacheOpenButton"
														Grid.Column="4"
														Text="{loc:Loc common.open}"
														Clicked="OnOpenPipCacheClicked"
														Style="{StaticResource SettingsTextButtonStyle}" />
												<Button x:Name="PipCacheClearButton"
														Grid.Column="5"
														Text="{loc:Loc settings.pip_cache.clear}"
														Clicked="OnClearPipCacheClicked"
														Style="{StaticResource SettingsTextButtonStyle}" />
											</Grid>
											<Label x:Name="PipCachePathValueLabel"
												   Grid.Row="10"
												   Style="{StaticResource SettingsValueStyle}"
												   LineBreakMode="TailTruncation" />
											<Label x:Name="PipCacheDetailValueLabel"
												   Grid.Row="11"
												   Style="{StaticResource SettingsHintStyle}" />
											<Label x:Name="PythonRuntimeQueueLabel"
												   Grid.Row="12"
												   TextColor="#8fdcff"
												   FontSize="10" />
										</Grid>
									</Border>
								</VerticalStackLayout>

								<VerticalStackLayout x:Name="ServerSection" Spacing="10">
									<Label Text="{loc:Loc views.overlays.settings_overlay_view.server}" Style="{StaticResource SettingsSectionTitleStyle}" />
									<Border Style="{StaticResource SettingsCardStyle}">
										<Grid ColumnDefinitions="1.1*,0.55*,1.9*" ColumnSpacing="16">
											<VerticalStackLayout Spacing="7">
												<Label Text="{loc:Loc views.overlays.settings_overlay_view.host}" Style="{StaticResource SettingsKeyStyle}" />
												<Entry x:Name="HostEntry"
													   TextChanged="OnDraftTextChanged"
													   Style="{StaticResource SettingsEntryStyle}" />
											</VerticalStackLayout>
											<VerticalStackLayout Grid.Column="1" Spacing="7">
												<Label Text="{loc:Loc views.overlays.settings_overlay_view.port}" Style="{StaticResource SettingsKeyStyle}" />
												<Entry x:Name="PortEntry"
													   Keyboard="Numeric"
													   TextChanged="OnDraftTextChanged"
													   Style="{StaticResource SettingsEntryStyle}" />
											</VerticalStackLayout>
											<VerticalStackLayout Grid.Column="2" Spacing="7">
												<Label Text="GPU" Style="{StaticResource SettingsKeyStyle}" />
												<Border Style="{StaticResource SettingsInsetBoxStyle}"
														Stroke="#1431d8ff"
														StrokeThickness="1"
														Padding="12,0"
														HeightRequest="56">
													<Grid>
														<Grid ColumnDefinitions="*,Auto"
															  ColumnSpacing="10"
															  HeightRequest="40"
															  VerticalOptions="Center">
															<VerticalStackLayout Spacing="1"
																				 VerticalOptions="Center">
																<Label x:Name="SelectedGpuLabel"
																	   Text="GPU 0"
																	   TextColor="#e8f8ff"
																	   FontSize="12"
																	   FontAttributes="Bold"
																	   HeightRequest="17"
																	   VerticalTextAlignment="Center"
																	   LineBreakMode="TailTruncation" />
																<Label x:Name="SelectedGpuDetailLabel"
																	   Text="{loc:Loc views.overlays.settings_overlay_view.detecting_gpu}"
																	   TextColor="#7fa0b8"
																	   FontSize="10"
																	   HeightRequest="15"
																	   VerticalTextAlignment="Center"
																	   LineBreakMode="TailTruncation" />
															</VerticalStackLayout>
															<Label Grid.Column="1"
																   Text="v"
																   TextColor="#8fdcff"
																   FontSize="14"
																   FontAttributes="Bold"
																   HeightRequest="20"
																   VerticalOptions="Center" />
														</Grid>
														<Picker x:Name="GpuPicker"
																Title="{loc:Loc views.overlays.settings_overlay_view.select_gpu}"
																Opacity="0.01"
																TextColor="Transparent"
																TitleColor="Transparent"
																FontSize="12"
																FontAttributes="Bold"
																BackgroundColor="Transparent"
																HorizontalOptions="Fill"
																VerticalOptions="Fill"
																HeightRequest="56"
																Margin="0"
																SelectedIndexChanged="OnGpuPickerSelectedIndexChanged" />
													</Grid>
												</Border>
											</VerticalStackLayout>
										</Grid>
									</Border>
