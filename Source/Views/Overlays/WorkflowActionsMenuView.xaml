<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 x:Class="ComfyUI_Nexus.Views.Overlays.WorkflowActionsMenuView">
	<Grid x:Name="WorkflowActionsOverlayRoot"
		  IsVisible="False"
		  InputTransparent="True">
		<Grid.GestureRecognizers>
			<TapGestureRecognizer Tapped="OnBackdropTapped" />
		</Grid.GestureRecognizers>

		<Border x:Name="WorkflowActionsMenuBorder"
				Opacity="0"
				StrokeThickness="0"
				Padding="6"
				Margin="58,0,0,0"
				WidthRequest="172"
				HorizontalOptions="Start"
				VerticalOptions="Start">
			<Border.Background>
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
					<GradientStop Color="{StaticResource WorkflowActionsMenuStartColor}" Offset="0.0" />
					<GradientStop Color="{StaticResource WorkflowActionsMenuMiddleColor}" Offset="0.52" />
					<GradientStop Color="{StaticResource WorkflowActionsMenuEndColor}" Offset="1.0" />
				</LinearGradientBrush>
			</Border.Background>
			<Border.StrokeShape>
				<RoundRectangle CornerRadius="12" />
			</Border.StrokeShape>
			<VerticalStackLayout x:Name="WorkflowActionsStack" Spacing="2" />
		</Border>
	</Grid>
</ContentView>
