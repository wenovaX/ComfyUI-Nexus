<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:loc="clr-namespace:ComfyUI_Nexus.Localization"
			 x:Class="ComfyUI_Nexus.Views.Overlays.CanvasToolbarView"
			 x:Name="CanvasToolbarRoot">
	<ContentView.Resources>
		<Style x:Key="CanvasToolbarButtonStyle" TargetType="Button">
			<Setter Property="BackgroundColor" Value="Transparent" />
			<Setter Property="TextColor" Value="{StaticResource CanvasToolbarTextColor}" />
			<Setter Property="FontSize" Value="10" />
			<Setter Property="FontAttributes" Value="Bold" />
			<Setter Property="HeightRequest" Value="24" />
			<Setter Property="MinimumHeightRequest" Value="0" />
			<Setter Property="Padding" Value="8,0" />
			<Setter Property="VerticalOptions" Value="Center" />
			<Setter Property="CornerRadius" Value="4" />
			<Setter Property="VisualStateManager.VisualStateGroups">
				<VisualStateGroupList>
					<VisualStateGroup x:Name="CommonStates">
						<VisualState x:Name="Normal" />
						<VisualState x:Name="PointerOver">
							<VisualState.Setters>
								<Setter Property="BackgroundColor" Value="{StaticResource CanvasToolbarHoverColor}" />
								<Setter Property="TextColor" Value="{StaticResource CanvasToolbarTextHoverColor}" />
							</VisualState.Setters>
						</VisualState>
						<VisualState x:Name="Pressed">
							<VisualState.Setters>
								<Setter Property="BackgroundColor" Value="{StaticResource CanvasToolbarPressedColor}" />
							</VisualState.Setters>
						</VisualState>
					</VisualStateGroup>
				</VisualStateGroupList>
			</Setter>
		</Style>
		<Style x:Key="CanvasToolbarSeparatorStyle" TargetType="BoxView">
			<Setter Property="WidthRequest" Value="1" />
			<Setter Property="HeightRequest" Value="14" />
			<Setter Property="BackgroundColor" Value="{StaticResource CanvasToolbarSeparatorColor}" />
			<Setter Property="VerticalOptions" Value="Center" />
			<Setter Property="Margin" Value="2,0" />
			<Setter Property="Opacity" Value="0.6" />
		</Style>
	</ContentView.Resources>

	<Border BackgroundColor="{StaticResource CanvasToolbarSurfaceColor}"
			StrokeThickness="0"
			HeightRequest="32"
			VerticalOptions="End"
			HorizontalOptions="Fill">

		<Grid>
			<!-- Top separator line. -->
			<BoxView HeightRequest="1"
					 BackgroundColor="{StaticResource CanvasToolbarTopLineColor}"
					 VerticalOptions="Start"
					 HorizontalOptions="Fill" />

			<HorizontalStackLayout HorizontalOptions="Start"
								   VerticalOptions="Center"
								   Spacing="2"
								   Margin="10,0,0,0">

				<Button Text="{loc:Loc common.help}" ToolTipProperties.Text="{loc:Loc views.overlays.canvas_toolbar_view.help_center}" SemanticProperties.Description="{loc:Loc views.overlays.canvas_toolbar_view.help_center}" SemanticProperties.Hint="{loc:Loc views.overlays.canvas_toolbar_view.help_center_help}" Style="{StaticResource CanvasToolbarButtonStyle}" Command="{Binding HelpCommand, Source={x:Reference CanvasToolbarRoot}}" />
				<BoxView Style="{StaticResource CanvasToolbarSeparatorStyle}" />
				<Button x:Name="TerminalButton" Text="{loc:Loc views.overlays.canvas_toolbar_view.terminal}" SemanticProperties.Description="{loc:Loc views.overlays.canvas_toolbar_view.terminal}" SemanticProperties.Hint="{loc:Loc views.overlays.canvas_toolbar_view.terminal_help}" Style="{StaticResource CanvasToolbarButtonStyle}" Command="{Binding TerminalCommand, Source={x:Reference CanvasToolbarRoot}}" />
				<BoxView Style="{StaticResource CanvasToolbarSeparatorStyle}" />
				<Button x:Name="ShortcutsButton" Text="{loc:Loc views.overlays.canvas_toolbar_view.shortcuts}" SemanticProperties.Description="{loc:Loc views.overlays.canvas_toolbar_view.shortcuts}" SemanticProperties.Hint="{loc:Loc views.overlays.canvas_toolbar_view.shortcuts_help}" Style="{StaticResource CanvasToolbarButtonStyle}" Command="{Binding ShortcutsCommand, Source={x:Reference CanvasToolbarRoot}}" />

			</HorizontalStackLayout>

			<HorizontalStackLayout HorizontalOptions="End"
								   VerticalOptions="Center"
								   Spacing="2"
								   Margin="0,0,10,0">

				<Button x:Name="ModeButton" Text="{loc:Loc common.hand}" SemanticProperties.Description="{loc:Loc views.overlays.canvas_toolbar_view.mode}" SemanticProperties.Hint="{loc:Loc views.overlays.canvas_toolbar_view.mode_help}" Style="{StaticResource CanvasToolbarButtonStyle}" Command="{Binding ModeCommand, Source={x:Reference CanvasToolbarRoot}}" />

				<BoxView Style="{StaticResource CanvasToolbarSeparatorStyle}" />

				<Button Text="{loc:Loc views.overlays.canvas_toolbar_view.fit}" SemanticProperties.Description="{loc:Loc views.overlays.canvas_toolbar_view.fit}" SemanticProperties.Hint="{loc:Loc views.overlays.canvas_toolbar_view.fit_help}" Style="{StaticResource CanvasToolbarButtonStyle}" Command="{Binding FitViewCommand, Source={x:Reference CanvasToolbarRoot}}" />
				<Button x:Name="ZoomButton" Text="100%" SemanticProperties.Description="{loc:Loc views.overlays.canvas_toolbar_view.zoom}" SemanticProperties.Hint="{loc:Loc views.overlays.canvas_toolbar_view.zoom_help}" Style="{StaticResource CanvasToolbarButtonStyle}" Command="{Binding ZoomCommand, Source={x:Reference CanvasToolbarRoot}}" />

				<BoxView Style="{StaticResource CanvasToolbarSeparatorStyle}" />

				<Button x:Name="MinimapButton" Text="{loc:Loc views.overlays.canvas_toolbar_view.map}" SemanticProperties.Description="{loc:Loc views.overlays.canvas_toolbar_view.map}" SemanticProperties.Hint="{loc:Loc views.overlays.canvas_toolbar_view.map_help}" Style="{StaticResource CanvasToolbarButtonStyle}" Command="{Binding GuardedMinimapCommand, Source={x:Reference CanvasToolbarRoot}}" />
				<Button x:Name="LinksButton" Text="{loc:Loc views.overlays.canvas_toolbar_view.links}" SemanticProperties.Description="{loc:Loc views.overlays.canvas_toolbar_view.links}" SemanticProperties.Hint="{loc:Loc views.overlays.canvas_toolbar_view.links_help}" Style="{StaticResource CanvasToolbarButtonStyle}" Command="{Binding GuardedLinksCommand, Source={x:Reference CanvasToolbarRoot}}" />

			</HorizontalStackLayout>
		</Grid>
	</Border>
</ContentView>
