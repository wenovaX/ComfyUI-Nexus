<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:loc="clr-namespace:ComfyUI_Nexus.Localization"
			 x:Class="ComfyUI_Nexus.Views.Overlays.CanvasToolbarView">
	<ContentView.Resources>
		<Style x:Key="CanvasToolbarButtonStyle" TargetType="Button">
			<Setter Property="BackgroundColor" Value="Transparent" />
			<Setter Property="TextColor" Value="#88e4ff" />
			<Setter Property="FontSize" Value="10" />
			<Setter Property="FontAttributes" Value="Bold" />
			<Setter Property="HeightRequest" Value="24" />
			<Setter Property="MinimumHeightRequest" Value="0" />
			<Setter Property="Padding" Value="8,0" />
			<Setter Property="VerticalOptions" Value="Center" />
			<Setter Property="CornerRadius" Value="4" />
			<Setter Property="VisualStateManager.VisualStateGroups">
				<VisualStateGroupList>
					<VisualStateGroup x:Name="CommonStates">
						<VisualState x:Name="Normal" />
						<VisualState x:Name="PointerOver">
							<VisualState.Setters>
								<Setter Property="BackgroundColor" Value="#1d2a3d" />
								<Setter Property="TextColor" Value="#f3feff" />
							</VisualState.Setters>
						</VisualState>
						<VisualState x:Name="Pressed">
							<VisualState.Setters>
								<Setter Property="BackgroundColor" Value="#102030" />
							</VisualState.Setters>
						</VisualState>
					</VisualStateGroup>
				</VisualStateGroupList>
			</Setter>
		</Style>
		<Style x:Key="CanvasToolbarSeparatorStyle" TargetType="BoxView">
			<Setter Property="WidthRequest" Value="1" />
			<Setter Property="HeightRequest" Value="14" />
			<Setter Property="BackgroundColor" Value="#22334a" />
			<Setter Property="VerticalOptions" Value="Center" />
			<Setter Property="Margin" Value="2,0" />
			<Setter Property="Opacity" Value="0.6" />
		</Style>
	</ContentView.Resources>

	<Border BackgroundColor="#0b121c"
			StrokeThickness="0"
			HeightRequest="32"
			VerticalOptions="End"
			HorizontalOptions="Fill">

		<Grid>
			<!-- Top separator line. -->
			<BoxView HeightRequest="1"
					 BackgroundColor="#1a2244"
					 VerticalOptions="Start"
					 HorizontalOptions="Fill" />

			<HorizontalStackLayout HorizontalOptions="Start"
								   VerticalOptions="Center"
								   Spacing="2"
								   Margin="10,0,0,0">

				<Button Text="{loc:Loc common.help}" ToolTipProperties.Text="{loc:Loc views.overlays.canvas_toolbar_view.help_center}" Style="{StaticResource CanvasToolbarButtonStyle}" Clicked="OnHelpClicked" />
				<BoxView Style="{StaticResource CanvasToolbarSeparatorStyle}" />
				<Button x:Name="TerminalButton" Text="{loc:Loc views.overlays.canvas_toolbar_view.terminal}" Style="{StaticResource CanvasToolbarButtonStyle}" Clicked="OnTerminalClicked" />
				<BoxView Style="{StaticResource CanvasToolbarSeparatorStyle}" />
				<Button x:Name="ShortcutsButton" Text="{loc:Loc views.overlays.canvas_toolbar_view.shortcuts}" Style="{StaticResource CanvasToolbarButtonStyle}" Clicked="OnShortcutsClicked" />

			</HorizontalStackLayout>

			<HorizontalStackLayout HorizontalOptions="End"
								   VerticalOptions="Center"
								   Spacing="2"
								   Margin="0,0,10,0">

				<Button x:Name="ModeButton" Text="{loc:Loc common.hand}" Style="{StaticResource CanvasToolbarButtonStyle}" Clicked="OnModeClicked" />

				<BoxView Style="{StaticResource CanvasToolbarSeparatorStyle}" />

				<Button Text="{loc:Loc views.overlays.canvas_toolbar_view.fit}" Style="{StaticResource CanvasToolbarButtonStyle}" Clicked="OnFitViewClicked" />
				<Button x:Name="ZoomButton" Text="100%" Style="{StaticResource CanvasToolbarButtonStyle}" Clicked="OnZoomClicked" />

				<BoxView Style="{StaticResource CanvasToolbarSeparatorStyle}" />

				<Button x:Name="MinimapButton" Text="{loc:Loc views.overlays.canvas_toolbar_view.map}" Style="{StaticResource CanvasToolbarButtonStyle}" Clicked="OnMinimapClicked" />
				<Button x:Name="LinksButton" Text="{loc:Loc views.overlays.canvas_toolbar_view.links}" Style="{StaticResource CanvasToolbarButtonStyle}" Clicked="OnLinksClicked" />

			</HorizontalStackLayout>
		</Grid>
	</Border>
</ContentView>
