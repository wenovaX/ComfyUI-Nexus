								<TapGestureRecognizer Tapped="OnBackClicked" />
								<PointerGestureRecognizer PointerEntered="OnBackButtonHovered" PointerExited="OnBackButtonUnhovered" />
							</Border.GestureRecognizers>
							<VisualStateManager.VisualStateGroups>
								<VisualStateGroup>
									<VisualState x:Name="BackNormal" />
									<VisualState x:Name="BackPointerOver">
										<VisualState.Setters>
											<Setter Property="BackgroundColor" Value="#26ffffff" />
											<Setter Property="Stroke" Value="#ffffff" />
										</VisualState.Setters>
									</VisualState>
								</VisualStateGroup>
							</VisualStateManager.VisualStateGroups>
							<Label Text="{loc:Loc views.overlays.product_setup_view.back}"
								   TextColor="#7fa0b8"
								   FontSize="13"
								   FontAttributes="Bold"
								   CharacterSpacing="1"
								   HorizontalOptions="Center"
								   VerticalOptions="Center" />
						</Border>

						<!-- PRIMARY ACTION -->
						<Border x:Name="PrimaryActionButton"
								Grid.Column="2"
								WidthRequest="220" HeightRequest="48"
								BackgroundColor="Transparent"
								Stroke="#4D31d8ff"
								StrokeThickness="1"
								StrokeShape="RoundRectangle 8">
							<Border.GestureRecognizers>
								<TapGestureRecognizer Tapped="OnPrimaryActionClicked" />
								<PointerGestureRecognizer PointerEntered="OnPrimaryButtonHovered" PointerExited="OnPrimaryButtonUnhovered" />
							</Border.GestureRecognizers>
							<Grid>
								<!-- PULSE GLOW LAYER -->
								<Border x:Name="PrimaryActionPulseGlow"
										Opacity="0"
										StrokeThickness="2"
										Stroke="#31d8ff"
										BackgroundColor="Transparent"
										StrokeShape="RoundRectangle 8"
										InputTransparent="True">
								</Border>

								<Label x:Name="PrimaryActionLabel"
									   Text="{loc:Loc views.overlays.product_setup_view.start}"
									   TextColor="#31d8ff"
									   FontSize="14"
									   FontAttributes="Bold"
									   CharacterSpacing="2"
									   HorizontalOptions="Center"
									   VerticalOptions="Center" />
							</Grid>
							<VisualStateManager.VisualStateGroups>
								<VisualStateGroup>
									<VisualState x:Name="PrimaryNormal" />
									<VisualState x:Name="PrimaryPointerOver">
										<VisualState.Setters>
											<Setter Property="BackgroundColor" Value="#4D31d8ff" />
											<Setter Property="Stroke" Value="#ffffff" />
										</VisualState.Setters>
									</VisualState>
								</VisualStateGroup>
							</VisualStateManager.VisualStateGroups>
						</Border>
					</Grid>
				</Grid>
			</Border>
		</Grid> <!-- End of MainUIPrefab -->

	</AbsoluteLayout>

	<!-- LAYER 4: Input Blocker -->
	<Grid x:Name="CinematicOverlay"
		  HorizontalOptions="Fill"
		  VerticalOptions="Fill"
		  BackgroundColor="Transparent"
		  InputTransparent="False"
		  ZIndex="20000">
		<Grid.GestureRecognizers>
			<TapGestureRecognizer Tapped="OnBlockerTapped" />
		</Grid.GestureRecognizers>
	</Grid>
</Grid>
</ContentView>
