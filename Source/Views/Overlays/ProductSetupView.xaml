<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
	xmlns:loc="clr-namespace:ComfyUI_Nexus.Localization"
			 xmlns:components="clr-namespace:ComfyUI_Nexus.Views.Components"
			 xmlns:diagnostics="clr-namespace:ComfyUI_Nexus.Setup.Diagnostics"
			 x:Class="ComfyUI_Nexus.Views.Overlays.ProductSetupView"
			 BackgroundColor="#050505"
			 HorizontalOptions="Fill"
			 VerticalOptions="Fill"
			 MinimumWidthRequest="800"
			 MinimumHeightRequest="600">

	<ContentView.Resources>
		<ResourceDictionary>
			<Color x:Key="SetupCardActionTextColor">#FFFFFF</Color>
			<Color x:Key="SetupCardDescriptionTextColor">#A0FFFFFF</Color>
			<Color x:Key="SetupAccentColor">#31d8ff</Color>
			<Color x:Key="SetupAccentFaintColor">#1A31d8ff</Color>
			<Color x:Key="SetupAccentMidColor">#4D31d8ff</Color>
			<Color x:Key="SetupGlassHoverColor">#1AFFFFFF</Color>
			<Color x:Key="SetupTextPrimaryColor">#ffffff</Color>
			<Color x:Key="SetupTextMutedColor">#7fa0b8</Color>
			<Color x:Key="SetupHealthyStrongColor">#2600ff88</Color>
			<Color x:Key="SetupHealthySoftColor">#0D00ff88</Color>
			<Color x:Key="SetupHoverHealthyStrongColor">#2C00ff88</Color>
			<Color x:Key="SetupHoverHealthySoftColor">#1200ff88</Color>

			<!-- Base Card Title (VANGUARD / ARCHITECT) -->
			<Style x:Key="CardTitleStyle" TargetType="Label">
				<Setter Property="FontSize" Value="28" />
				<Setter Property="FontAttributes" Value="Bold" />
				<Setter Property="CharacterSpacing" Value="2" />
				<Setter Property="Margin" Value="0,0,0,8" />
				<Setter Property="InputTransparent" Value="True" />
			</Style>

			<!-- Accent Line -->
			<Style x:Key="CardAccentLineStyle" TargetType="BoxView">
				<Setter Property="HeightRequest" Value="2" />
				<Setter Property="WidthRequest" Value="60" />
				<Setter Property="HorizontalOptions" Value="Start" />
				<Setter Property="Margin" Value="0,0,0,20" />
				<Setter Property="InputTransparent" Value="True" />
			</Style>

			<!-- Action Text (DEPLOY NEW...) -->
			<Style x:Key="CardActionStyle" TargetType="Label">
				<Setter Property="TextColor" Value="{StaticResource SetupCardActionTextColor}" />
				<Setter Property="FontSize" Value="16" />
				<Setter Property="FontAttributes" Value="Bold" />
				<Setter Property="Margin" Value="0,0,0,8" />
				<Setter Property="InputTransparent" Value="True" />
			</Style>

			<!-- Description Text -->
			<Style x:Key="CardDescStyle" TargetType="Label">
				<Setter Property="TextColor" Value="{StaticResource SetupCardDescriptionTextColor}" />
				<Setter Property="FontSize" Value="14" />
				<Setter Property="LineBreakMode" Value="WordWrap" />
				<Setter Property="InputTransparent" Value="True" />
			</Style>

			<!-- SHARED DIAGNOSTIC NODE TEMPLATE -->
			<DataTemplate x:Key="DiagnosticNodeTemplate" x:DataType="diagnostics:DiagnosticNodeViewModel">
				<Border StrokeThickness="0" BackgroundColor="{Binding HighlightBackground}" StrokeShape="RoundRectangle 12" Padding="16,0" Margin="0,4" MinimumHeightRequest="120">
					<Border.GestureRecognizers>
						<PointerGestureRecognizer PointerEntered="OnGlassItemHovered" PointerExited="OnGlassItemUnhovered" />
					</Border.GestureRecognizers>
					<Border.Triggers>
						<DataTrigger TargetType="Border" Binding="{Binding CurrentHealth}" Value="Healthy">
							<Setter Property="Background">
								<Setter.Value>
									<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
										<GradientStop Color="{StaticResource SetupHealthyStrongColor}" Offset="0.0" />
										<GradientStop Color="{StaticResource SetupHealthySoftColor}" Offset="0.6" />
										<GradientStop Color="Transparent" Offset="1.0" />
									</LinearGradientBrush>
								</Setter.Value>
							</Setter>
							<Setter Property="StrokeShape" Value="Rectangle" />
							<Setter Property="Margin" Value="0" />
						</DataTrigger>

						<DataTrigger TargetType="Border" Binding="{Binding IsAdvisoryNode}" Value="True">
							<Setter Property="Background">
								<Setter.Value>
									<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
										<GradientStop Color="{StaticResource SetupAccentFaintColor}" Offset="0.0" />
										<GradientStop Color="#0F8ecfff" Offset="0.45" />
										<GradientStop Color="Transparent" Offset="1.0" />
									</LinearGradientBrush>
								</Setter.Value>
							</Setter>
							<Setter Property="StrokeShape" Value="Rectangle" />
							<Setter Property="Margin" Value="0" />
						</DataTrigger>

						<DataTrigger TargetType="Border" Binding="{Binding IsLoading}" Value="True">
							<Setter Property="Background">
								<Setter.Value>
									<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
										<GradientStop Color="{StaticResource SetupAccentMidColor}" Offset="0.0" />
										<GradientStop Color="{StaticResource SetupAccentFaintColor}" Offset="0.5" />
										<GradientStop Color="Transparent" Offset="1.0" />
									</LinearGradientBrush>
								</Setter.Value>
							</Setter>
							<Setter Property="StrokeShape" Value="Rectangle" />
							<Setter Property="Margin" Value="0" />
						</DataTrigger>
					</Border.Triggers>
					<Grid>
						<Border Opacity="{Binding InteractionOverlayOpacity}"
								StrokeThickness="0"
								StrokeShape="RoundRectangle 12"
								InputTransparent="True">
							<Border.Background>
								<LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
									<GradientStop Color="{StaticResource SetupHoverHealthyStrongColor}" Offset="0.0" />
									<GradientStop Color="{StaticResource SetupHoverHealthySoftColor}" Offset="0.55" />
									<GradientStop Color="Transparent" Offset="1.0" />
								</LinearGradientBrush>
							</Border.Background>
							<Border.Triggers>
								<DataTrigger TargetType="Border" Binding="{Binding IsAdvisoryNode}" Value="True">
									<Setter Property="Background">
										<Setter.Value>
											<LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
												<GradientStop Color="#3031d8ff" Offset="0.0" />
												<GradientStop Color="#148ecfff" Offset="0.55" />
												<GradientStop Color="Transparent" Offset="1.0" />
											</LinearGradientBrush>
										</Setter.Value>
									</Setter>
								</DataTrigger>
							</Border.Triggers>
						</Border>

						<Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
							<!-- Status Icon -->
							<Grid WidthRequest="44" HeightRequest="44" VerticalOptions="Center">
								<Grid.Triggers>
									<DataTrigger TargetType="Grid" Binding="{Binding IsLoading}" Value="True">
										<Setter Property="Scale" Value="1.2" />
									</DataTrigger>
								</Grid.Triggers>
								<Border StrokeThickness="1" Stroke="{Binding StatusBrush}" BackgroundColor="{StaticResource SetupGlassHoverColor}" Opacity="0.4" StrokeShape="RoundRectangle 8" />
								<Border x:Name="DiagnosticLoadingRing"
										StyleId="DiagnosticLoadingRing"
										WidthRequest="38"
										HeightRequest="38"
										Stroke="{StaticResource SetupAccentColor}"
										StrokeThickness="2"
										StrokeShape="RoundRectangle 19"
										Opacity="0"
										HorizontalOptions="Center"
										VerticalOptions="Center"
										Loaded="OnDiagnosticLoadingRingLoaded"
										Unloaded="OnDiagnosticLoadingRingUnloaded">
									<Border.Background>
										<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
											<GradientStop Color="#0031d8ff" Offset="0.0" />
											<GradientStop Color="#3331d8ff" Offset="0.35" />
											<GradientStop Color="#AA31d8ff" Offset="1.0" />
										</LinearGradientBrush>
									</Border.Background>
								</Border>
								<Image Source="{Binding IconSource}"
									   WidthRequest="24"
									   HeightRequest="24"
									   HorizontalOptions="Center"
									   VerticalOptions="Center" />
							</Grid>

							<StackLayout Padding="0, 10" Grid.Column="1" VerticalOptions="Center" Spacing="4">
								<Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
									<Label Grid.Column="0"
										   Text="{Binding DisplayName}"
										   TextColor="{StaticResource SetupTextPrimaryColor}"
										   FontSize="16"
										   FontAttributes="Bold"
										   LineBreakMode="TailTruncation" />
									<Label x:Name="DiagnosticEditLabel"
										   Grid.Column="1"
										   Text="[edit]"
										   TextColor="{StaticResource SetupAccentColor}"
										   FontSize="12"
										   FontAttributes="Bold"
										   VerticalOptions="Center"
										   IsVisible="{Binding CanHeaderEdit}">
										<Label.GestureRecognizers>
											<PointerGestureRecognizer PointerEntered="OnDiagnosticEditHovered" PointerExited="OnDiagnosticEditUnhovered" />
											<TapGestureRecognizer Tapped="OnDiagnosticNodeTapped" />
										</Label.GestureRecognizers>
									</Label>
								</Grid>
								<Label Text="{Binding Description}" TextColor="{StaticResource SetupTextMutedColor}" FontSize="13" LineBreakMode="WordWrap" />
								<Border IsVisible="{Binding HasEnvironmentDetails}"
										MinimumHeightRequest="{Binding EnvironmentDetailsMinHeight}"
										Margin="0,3,0,0"
										Padding="10,6"
										BackgroundColor="#1231d8ff"
										Stroke="#2631d8ff"
										StrokeThickness="1"
										StrokeShape="RoundRectangle 8">
									<Grid ColumnDefinitions="Auto,*" ColumnSpacing="9" VerticalOptions="Center">
										<Label Text="{loc:Loc setup.status.label}"
											   TextColor="#6631d8ff"
											   FontSize="9"
											   FontAttributes="Bold"
											   CharacterSpacing="1"
											   VerticalOptions="Center" />
										<Label Grid.Column="1"
											   Text="{Binding EnvironmentDetails}"
											   TextColor="{Binding DetailsColor}"
											   FontSize="12"
											   FontAttributes="Italic"
											   MaxLines="{Binding EnvironmentDetailsMaxLines}"
											   LineBreakMode="WordWrap"
											   VerticalOptions="Center" />
									</Grid>
								</Border>

								<!-- Clickable Environment Path -->
								<Label Text="{Binding EnvironmentDisplayPath}" TextColor="{StaticResource SetupAccentColor}" TextDecorations="Underline" FontSize="12" IsVisible="{Binding HasEnvironmentPath}" Margin="0,2,0,0" LineBreakMode="TailTruncation">
									<Label.GestureRecognizers>
										<PointerGestureRecognizer PointerEntered="OnPathHovered" PointerExited="OnPathUnhovered" />
										<TapGestureRecognizer Command="{Binding OpenPathCommand}" />
									</Label.GestureRecognizers>
								</Label>

							</StackLayout>

							<Grid Grid.Column="2"
								  MinimumHeightRequest="120"
								  VerticalOptions="Fill"
								  HorizontalOptions="End"
								  Padding="0,10,12,10">
								<VerticalStackLayout Spacing="8"
													 WidthRequest="190"
													 HorizontalOptions="End"
													 VerticalOptions="Center">
									<Label Text="{Binding ActionText}"
										   TextColor="{Binding StatusColor}"
										   FontSize="13"
										   FontAttributes="Bold"
										   CharacterSpacing="0.5"
										   HorizontalTextAlignment="Center"
										   VerticalTextAlignment="Center"
										   HorizontalOptions="Fill"
										   VerticalOptions="Center"
										   IsVisible="{Binding HasNoActions}" />
									<Border StrokeThickness="1"
											Stroke="{StaticResource SetupAccentColor}"
											BackgroundColor="#1210141F"
											StrokeShape="RoundRectangle 8"
											Padding="12,0"
											WidthRequest="190"
											HeightRequest="32"
											HorizontalOptions="Fill"
											IsVisible="{Binding CanStatusEdit}">
										<Border.GestureRecognizers>
											<PointerGestureRecognizer PointerEntered="OnDiagnosticRetryHovered" PointerExited="OnDiagnosticRetryUnhovered" />
											<TapGestureRecognizer Tapped="OnDiagnosticNodeTapped" />
										</Border.GestureRecognizers>
										<Label Text="{loc:Loc setup.status.edit}"
											   TextColor="{StaticResource SetupAccentColor}"
											   FontSize="10"
											   FontAttributes="Bold"
											   CharacterSpacing="1"
											   HorizontalTextAlignment="Center"
											   VerticalTextAlignment="Center"
											   HorizontalOptions="Center"
											   VerticalOptions="Center" />
									</Border>
									<Label Text="{Binding OperationProgressText}"
										   TextColor="{StaticResource SetupAccentColor}"
										   FontSize="10"
										   FontAttributes="Bold"
										   LineBreakMode="TailTruncation"
										   HorizontalTextAlignment="Center"
										   HorizontalOptions="Fill"
										   IsVisible="{Binding HasOperationProgressText}" />
									<Label Text="{Binding WorkingHint}"
										   TextColor="{StaticResource SetupTextMutedColor}"
										   FontSize="10"
										   FontAttributes="Italic"
										   LineBreakMode="WordWrap"
										   MaxLines="2"
										   HorizontalTextAlignment="Center"
										   HorizontalOptions="Fill"
										   IsVisible="{Binding HasWorkingHint}" />

									<Border StrokeThickness="1"
											Stroke="{StaticResource SetupAccentColor}"
											BackgroundColor="#1210141F"
											StrokeShape="RoundRectangle 8"
											Padding="12,0"
											WidthRequest="190"
											HeightRequest="32"
											HorizontalOptions="Fill"
											IsVisible="{Binding CanCancel}">
										<Border.GestureRecognizers>
											<PointerGestureRecognizer PointerEntered="OnDiagnosticRetryHovered" PointerExited="OnDiagnosticRetryUnhovered" />
											<TapGestureRecognizer Tapped="OnDiagnosticCancelTapped" />
										</Border.GestureRecognizers>
										<Label Text="{loc:Loc common.cancel}"
											   TextColor="{StaticResource SetupAccentColor}"
											   FontSize="10"
											   FontAttributes="Bold"
											   CharacterSpacing="1"
											   HorizontalTextAlignment="Center"
											   VerticalTextAlignment="Center"
											   HorizontalOptions="Center"
											   VerticalOptions="Center" />
									</Border>

									<Border StrokeThickness="1"
											Stroke="{Binding StatusBrush}"
											BackgroundColor="#1210141F"
											StrokeShape="RoundRectangle 8"
											Padding="12,0"
											WidthRequest="190"
											HeightRequest="32"
											HorizontalOptions="Fill"
											IsVisible="{Binding CanRetry}">
										<Border.GestureRecognizers>
											<PointerGestureRecognizer PointerEntered="OnDiagnosticRetryHovered" PointerExited="OnDiagnosticRetryUnhovered" />
											<TapGestureRecognizer Tapped="OnDiagnosticRetryTapped" />
										</Border.GestureRecognizers>
										<Label Text="RETRY"
											   TextColor="{Binding StatusColor}"
											   FontSize="10"
											   FontAttributes="Bold"
											   CharacterSpacing="1"
											   HorizontalTextAlignment="Center"
											   VerticalTextAlignment="Center"
											   HorizontalOptions="Center"
											   VerticalOptions="Center" />
									</Border>

									<StackLayout BindableLayout.ItemsSource="{Binding Actions}"
												 IsVisible="{Binding HasActions}"
												 Spacing="4"
												 HorizontalOptions="End"
												 VerticalOptions="Center">
										<BindableLayout.ItemTemplate>
											<DataTemplate x:DataType="diagnostics:DiagnosticActionViewModel">
												<Border StrokeThickness="0"
														BackgroundColor="{Binding NormalBackground}"
														StrokeShape="RoundRectangle 8"
														Padding="10,6"
														WidthRequest="190"
														MinimumHeightRequest="32"
														HorizontalOptions="End">
													<Border.GestureRecognizers>
														<PointerGestureRecognizer PointerEntered="OnGlassItemHovered" PointerExited="OnGlassItemUnhovered" />
														<TapGestureRecognizer Command="{Binding Command}" />
													</Border.GestureRecognizers>
													<VerticalStackLayout Spacing="2"
																		 HorizontalOptions="Fill"
																		 VerticalOptions="Center">
														<Label Text="{Binding DisplayName}"
															   TextColor="{Binding TextColor}"
															   FontSize="11"
															   FontAttributes="Bold"
															   LineBreakMode="TailTruncation"
															   HorizontalTextAlignment="Center"
															   VerticalTextAlignment="Center"
															   HorizontalOptions="Fill"
															   VerticalOptions="Center" />
														<Label Text="{Binding Description}"
															   TextColor="{StaticResource SetupTextMutedColor}"
															   FontSize="9"
															   LineBreakMode="WordWrap"
															   MaxLines="2"
															   HorizontalTextAlignment="Center"
															   HorizontalOptions="Fill"
															   IsVisible="{Binding HasDescription}" />
													</VerticalStackLayout>
												</Border>
											</DataTemplate>
										</BindableLayout.ItemTemplate>
									</StackLayout>
								</VerticalStackLayout>
							</Grid>
						</Grid>
					</Grid>
				</Border>
			</DataTemplate>
		</ResourceDictionary>
	</ContentView.Resources>

	<Grid x:Name="ProductSetupRoot"
		  HorizontalOptions="Fill"
		  VerticalOptions="Fill">
		<!-- LAYER 1: BACKGROUND (Deep Space & Particles) -->
		<Grid x:Name="BackgroundLayer">
			<Image Source="nexus_setup_bg.png"
				   Aspect="AspectFill" />
			<Grid x:Name="ParticleContainer" InputTransparent="True" CascadeInputTransparent="True" />
		</Grid>

		<!-- LAYER 1.5: GLOBAL CINEMATIC GLOW (Unclipped) -->
		<Grid x:Name="GlobalGlowLayer" InputTransparent="True" CascadeInputTransparent="True">
			<Grid x:Name="GlowSyncGroup"
				  ColumnDefinitions="*, *"
				  WidthRequest="1150"
				  HeightRequest="1000"
				  VerticalOptions="Center"
				  HorizontalOptions="Center">
				<Image x:Name="VanguardGlow"
					   Grid.Column="0"
					   Source="hover_cloud_vanguard.png"
					   Aspect="AspectFit"
					   WidthRequest="1200"
					   HeightRequest="1000"
					   Opacity="0.15"
					   HorizontalOptions="Center"
					   VerticalOptions="Center" />
				<Image x:Name="ArchitectGlow"
					   Grid.Column="1"
					   Source="hover_cloud_architect.png"
					   Aspect="AspectFit"
					   WidthRequest="1200"
					   HeightRequest="1000"
					   Opacity="0.15"
					   HorizontalOptions="Center"
					   VerticalOptions="Center" />
			</Grid>
		</Grid>

		<AbsoluteLayout x:Name="ScaleContainer"
						HorizontalOptions="Fill"
						VerticalOptions="Fill"
						InputTransparent="True">
			<AbsoluteLayout.GestureRecognizers>
				<PointerGestureRecognizer PointerMoved="OnGlobalPointerMoved" />
			</AbsoluteLayout.GestureRecognizers>

			<!-- Main UI Prefab Wrapper -->
			<Grid x:Name="MainUIPrefab"
				  AbsoluteLayout.LayoutBounds="0.5,0.5,1150,1000"
				  AbsoluteLayout.LayoutFlags="PositionProportional">

				<!-- PIERCING HEADER -->
				<Grid x:Name="HeaderBar"
					  VerticalOptions="Start"
					  HorizontalOptions="Center"
					  Margin="0,50,0,0"
					  Opacity="0"
					  IsVisible="False">
					<Image Source="top_logo_neon_glass.png"
						   HeightRequest="120"
						   Aspect="AspectFit" />
				</Grid>

				<Border x:Name="GlassPanel"
						VerticalOptions="End"
						HeightRequest="768"
						WidthRequest="1150"
						StrokeThickness="0"
						StrokeShape="RoundRectangle 32"
						BackgroundColor="#26050A14">

					<Grid RowDefinitions="*,Auto"
						  Padding="60,40,60,40">
						<!-- Content area -->
						<Grid Grid.Row="0">

						<!-- CROSSROADS STATE -->
						<StackLayout x:Name="WelcomeContainer"
									 IsVisible="False"
									 Opacity="0"
									 VerticalOptions="Center"
									 Spacing="48">

							<Label Text="{loc:Loc views.overlays.product_setup_view.select_your_deployment_strategy}"
								   TextColor="#7fa0b8"
								   FontSize="24"
								   FontAttributes="Bold"
								   CharacterSpacing="4"
								   HorizontalTextAlignment="Center" />

							<Grid ColumnDefinitions="*, *"
								  ColumnSpacing="32"
								  MaximumWidthRequest="1100"
								  HorizontalOptions="Center">

								<!-- VANGUARD WRAPPER (Allows overflow glow) -->
								<Grid x:Name="VanguardContainer" Grid.Column="0" HeightRequest="240">

									<!-- VANGUARD CARD -->
									<Border x:Name="VanguardCard"
											HeightRequest="240"
											StrokeThickness="0"
											StrokeShape="RoundRectangle 24"
											BackgroundColor="#1A000000"
											Padding="0"
											ZIndex="1">
										<Grid ColumnDefinitions="200, *" InputTransparent="True" CascadeInputTransparent="True">
											<!-- Object Prefab (Left) -->
											<Grid Grid.Column="0" InputTransparent="True">
												<Ellipse x:Name="VanguardRing1" Stroke="#4D31D8FF" StrokeThickness="1" Margin="25" StrokeDashArray="1,4" InputTransparent="True" />
												<Ellipse x:Name="VanguardRing2" Stroke="#2631D8FF" StrokeThickness="2" Margin="45" StrokeDashArray="10,5" InputTransparent="True" />
												<Image Source="setup_vanguard_high.png"
													   Aspect="AspectFill"
													   Opacity="0.8"
													   Margin="15"
													   x:Name="VanguardBgImage"
													   InputTransparent="True" />
											</Grid>

											<!-- Text Content (Right) -->
											<StackLayout Grid.Column="1" Padding="10,0,40,0" Spacing="0" VerticalOptions="Center" InputTransparent="True">
												<Label Text="VANGUARD"
													   Style="{StaticResource CardTitleStyle}"
													   TextColor="#31d8ff" />

												<BoxView Color="#31d8ff"
														 Style="{StaticResource CardAccentLineStyle}" />

												<Label Text="{loc:Loc views.overlays.product_setup_view.deploy_new_environment}"
													   Style="{StaticResource CardActionStyle}" />

												<Label Text="{loc:Loc views.overlays.product_setup_view.build_a_complete_isolated_comfyui_setup_from_scratch_wit}"
													   Style="{StaticResource CardDescStyle}" />
											</StackLayout>
										</Grid>
									</Border>

									<!-- EVENT PROXY -->
									<BoxView Grid.Column="0"
											 HeightRequest="240"
											 BackgroundColor="Transparent"
											 ZIndex="2">
										<BoxView.GestureRecognizers>
											<PointerGestureRecognizer PointerEntered="OnVanguardCardPointerEntered"
																	  PointerExited="OnVanguardCardPointerExited" />
											<TapGestureRecognizer Tapped="OnVanguardSelected" />
										</BoxView.GestureRecognizers>
									</BoxView>
								</Grid>

								<!-- ARCHITECT WRAPPER -->
								<Grid x:Name="ArchitectContainer" Grid.Column="1" HeightRequest="240">

									<!-- ARCHITECT CARD -->
									<Border x:Name="ArchitectCard"
											HeightRequest="240"
											StrokeThickness="0"
											StrokeShape="RoundRectangle 24"
											BackgroundColor="#1A000000"
											Padding="0"
											ZIndex="1">
										<Grid ColumnDefinitions="200, *" InputTransparent="True" CascadeInputTransparent="True">
											<!-- Object Prefab (Left) -->
											<Grid Grid.Column="0" InputTransparent="True">
												<Ellipse x:Name="ArchitectRing1" Stroke="#4Dc78bff" StrokeThickness="1" Margin="25" StrokeDashArray="2,6" InputTransparent="True" />
												<Ellipse x:Name="ArchitectRing2" Stroke="#26c78bff" StrokeThickness="2" Margin="45" StrokeDashArray="15,10" InputTransparent="True" />
												<Image Source="setup_architect_high.png"
													   Aspect="AspectFill"
													   Opacity="0.8"
													   Margin="15"
													   x:Name="ArchitectBgImage"
													   InputTransparent="True" />
											</Grid>

											<StackLayout Grid.Column="1" Padding="10,0,40,0" Spacing="0" VerticalOptions="Center" InputTransparent="True">
												<Label Text="ARCHITECT"
													   Style="{StaticResource CardTitleStyle}"
													   TextColor="#c78bff" />

												<BoxView Color="#c78bff"
														 Style="{StaticResource CardAccentLineStyle}" />

												<Label Text="{loc:Loc views.overlays.product_setup_view.connect_existing_path}"
													   Style="{StaticResource CardActionStyle}" />

												<Label Text="{loc:Loc views.overlays.product_setup_view.link_your_local_comfyui_folder_and_synchronize_with_nexu}"
													   Style="{StaticResource CardDescStyle}" />
											</StackLayout>
										</Grid>
									</Border>

									<!-- EVENT PROXY -->
									<BoxView Grid.Column="0"
											 HeightRequest="240"
											 BackgroundColor="Transparent"
											 ZIndex="2">
										<BoxView.GestureRecognizers>
											<PointerGestureRecognizer PointerEntered="OnArchitectCardPointerEntered"
																	  PointerExited="OnArchitectCardPointerExited" />
											<TapGestureRecognizer Tapped="OnArchitectSelected" />
										</BoxView.GestureRecognizers>
									</BoxView>
								</Grid>
							</Grid>
						</StackLayout>

						<!-- VANGUARD PANEL (Checklist) -->
						<Border x:Name="VanguardPanel"
								IsVisible="False"
								Opacity="0"
