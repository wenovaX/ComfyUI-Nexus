<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:loc="clr-namespace:ComfyUI_Nexus.Localization"
			 xmlns:components="clr-namespace:ComfyUI_Nexus.Views.Components"
			 xmlns:config="clr-namespace:ComfyUI_Nexus.Configuration"
			 x:Class="ComfyUI_Nexus.Views.ControlDeckView"
			 x:Name="ControlDeckRoot">
	<Border BackgroundColor="Transparent"
			Stroke="{StaticResource DeckStrokeColor}"
			StrokeThickness="1">
		<Grid>
			<Image Source="control_deck_telemetry_backdrop.png"
				   Aspect="AspectFill"
				   Opacity="0.16"
				   InputTransparent="True" />
			<BoxView Color="{StaticResource DeckPanelColor}"
					 Opacity="0.86"
					 InputTransparent="True" />
			<Grid RowDefinitions="Auto, Auto, Auto, Auto, *">
			<Border Grid.Row="0" BackgroundColor="{StaticResource DeckHeaderColor}" Padding="12,8" StrokeThickness="0">
				<Label Text="NEXUS CONTROL DECK" TextColor="{StaticResource DeckAccentColor}" FontSize="10" FontAttributes="Bold" CharacterSpacing="1" />
			</Border>

			<Border Grid.Row="1"
					Margin="10,10,10,2"
					Padding="10,8"
					BackgroundColor="#0c1420"
					Stroke="{StaticResource DeckStrokeColor}"
					StrokeThickness="1"
					StrokeShape="RoundRectangle 12">
				<Grid ColumnDefinitions="*" RowDefinitions="Auto, Auto" RowSpacing="7">
					<Grid ColumnDefinitions="Auto, *, Auto">
						<HorizontalStackLayout Spacing="6" VerticalOptions="Center">
							<BoxView WidthRequest="6"
									 HeightRequest="6"
									 CornerRadius="3"
									 Color="{StaticResource DeckAccentColor}"
									 Opacity="0.92"
									 VerticalOptions="Center" />
							<Label Text="PULSE"
								   TextColor="{StaticResource DeckTextSoftColor}"
								   FontSize="10"
								   FontAttributes="Bold"
								   CharacterSpacing="1.2"
								   VerticalOptions="Center" />
						</HorizontalStackLayout>

						<Label x:Name="PulseBridgeStatusLabel"
							   Grid.Column="2"
							   Text="BRIDGE ACTIVE"
							   TextColor="{StaticResource DeckPulseLiveTextColor}"
							   FontSize="9"
							   FontAttributes="Bold"
							   CharacterSpacing="0.8"
							   VerticalOptions="Center" />
					</Grid>

					<Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="6">
						<Border Grid.Column="0"
								BackgroundColor="#0a111d"
								Stroke="{StaticResource DeckStrokeColor}"
								StrokeThickness="1"
								StrokeShape="RoundRectangle 7"
								Padding="6,3">
							<Grid ColumnDefinitions="20,*" ColumnSpacing="5">
								<Grid WidthRequest="20" HeightRequest="26" InputTransparent="True">
									<Image x:Name="PulseRunIdleSurface"
										   Source="header_gpu_idle_energy_core.webp"
										   Aspect="AspectFit" />
									<Image x:Name="PulseRunActiveSurface"
										   Source="header_gpu_running_energy_core.webp"
										   Aspect="AspectFit"
										   Opacity="0" />
								</Grid>
								<Label x:Name="PulseRunLabel"
									   Grid.Column="1"
									   Text="RUN IDLE"
									   TextColor="{StaticResource DeckTextMutedColor}"
									   FontSize="8"
									   FontAttributes="Bold"
									   VerticalTextAlignment="Center" />
							</Grid>
						</Border>

						<Border Grid.Column="1"
								BackgroundColor="#0a111d"
								Stroke="{StaticResource DeckStrokeColor}"
								StrokeThickness="1"
								StrokeShape="RoundRectangle 7"
								Padding="6,3">
							<Grid ColumnDefinitions="20,*" ColumnSpacing="5">
								<Grid WidthRequest="20" HeightRequest="26" InputTransparent="True">
									<Image x:Name="PulseWebIdleSurface"
										   Source="header_gpu_idle_energy_core.webp"
										   Aspect="AspectFit"
										   Opacity="0.22" />
									<Image x:Name="PulseWebLiveSurface"
										   Source="header_gpu_running_energy_core.webp"
										   Aspect="AspectFit"
										   Opacity="0" />
								</Grid>
								<Label x:Name="PulseWebLabel"
									   Grid.Column="1"
									   Text="WEB IDLE"
									   TextColor="{StaticResource DeckTextMutedColor}"
									   FontSize="8"
									   FontAttributes="Bold"
									   VerticalTextAlignment="Center" />
							</Grid>
						</Border>
					</Grid>
				</Grid>
			</Border>

			<VerticalStackLayout Grid.Row="2" Padding="12,10" Spacing="8">
				<Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
					<Button Grid.Column="0"
							Text="RECONNECT"
							Command="{Binding ManualRebootCommand, Source={x:Reference ControlDeckRoot}}"
							Style="{StaticResource HudMiniButtonStyle}"
							TextColor="{StaticResource DeckAccentColor}"
							SemanticProperties.Description="{loc:Loc views.shell.control_deck_view.reboot}"
							SemanticProperties.Hint="{loc:Loc views.shell.control_deck_view.reboot_help}" />
					<Button Grid.Column="1"
							Text="BOOT SERVER"
							Command="{Binding BootServerCommand, Source={x:Reference ControlDeckRoot}}"
							Style="{StaticResource HudMiniButtonStyle}"
							TextColor="{StaticResource DeckAccentColor}" />
					<Button Grid.Column="2"
							Text="STOP SERVER"
							Command="{Binding ShutdownServerCommand, Source={x:Reference ControlDeckRoot}}"
							Style="{StaticResource HudMiniButtonStyle}"
							TextColor="{StaticResource DeckDangerColor}" />
				</Grid>

				<Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto" RowSpacing="2">
					<Grid Grid.Row="0" Grid.Column="0" ColumnDefinitions="*,Auto" HeightRequest="30">
						<Label Text="BRIDGE TRACE" TextColor="{StaticResource DeckTextSoftColor}" FontSize="10" VerticalOptions="Center" />
						<Switch x:Name="BridgeDiagnosticsToggle" Grid.Column="1" Toggled="OnBridgeDiagnosticsToggled" Scale="0.72" />
					</Grid>
					<Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto" HeightRequest="30">
						<Label Text="WEB LOGS" TextColor="{StaticResource DeckTextSoftColor}" FontSize="10" VerticalOptions="Center" />
						<Switch x:Name="WebLogsToggle" Grid.Column="1" Toggled="OnWebLogsToggled" Scale="0.72" />
					</Grid>
					<Grid Grid.Row="1" Grid.Column="0" ColumnDefinitions="*,Auto" HeightRequest="30">
						<Label Text="DEVTOOLS" TextColor="{StaticResource DeckTextSoftColor}" FontSize="10" VerticalOptions="Center" />
						<Switch x:Name="DevToolsToggle" Grid.Column="1" Toggled="OnDevToolsToggled" Scale="0.72" />
					</Grid>
					<Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,Auto" HeightRequest="30">
						<Label Text="UI ISOLATION" TextColor="{StaticResource DeckTextSoftColor}" FontSize="10" VerticalOptions="Center" />
						<Switch x:Name="UiIsolationToggle" Grid.Column="1" Toggled="OnUiIsolationToggled" Scale="0.72" />
					</Grid>
				</Grid>

				<Grid ColumnDefinitions="*,*" ColumnSpacing="6">
					<Button Grid.Column="0"
							Text="PATCH HUD"
							Command="{Binding PatchLocalHudCommand, Source={x:Reference ControlDeckRoot}}"
							Style="{StaticResource HudMiniButtonStyle}"
							TextColor="{StaticResource DeckPatchHudTextColor}"
							SemanticProperties.Description="{loc:Loc views.shell.control_deck_view.patch_hud}"
							SemanticProperties.Hint="{loc:Loc views.shell.control_deck_view.patch_hud_help}" />
					<Button Grid.Column="1"
							Text="PATCH BRIDGE"
							Command="{Binding PatchNexusBridgeCommand, Source={x:Reference ControlDeckRoot}}"
							Style="{StaticResource HudMiniButtonStyle}"
							TextColor="{StaticResource DeckPulseLiveTextColor}"
							SemanticProperties.Description="{loc:Loc views.shell.control_deck_view.patch_bridge}"
							SemanticProperties.Hint="{loc:Loc views.shell.control_deck_view.patch_bridge_help}" />
				</Grid>
			</VerticalStackLayout>

			<BoxView Grid.Row="3" HeightRequest="1" Color="{StaticResource DeckStrokeColor}" Margin="0,5" />

			<Grid Grid.Row="4" RowDefinitions="Auto, Auto, *">
				<Border Grid.Row="0" BackgroundColor="{StaticResource DeckHeaderColor}" Padding="12,8" StrokeThickness="0">
					<Grid ColumnDefinitions="Auto, *, Auto, Auto" ColumnSpacing="8">
					<Label Text="CONSOLE" TextColor="{StaticResource DeckAccentColor}" FontSize="10" FontAttributes="Bold" VerticalOptions="Center" />
						<Label x:Name="LogFilePathLabel"
							   Grid.Column="1"
							   Text="Logs/nexus-latest.log"
							   TextColor="{StaticResource DeckTextMutedColor}"
							   FontSize="9"
							   LineBreakMode="TailTruncation"
							   VerticalOptions="Center"
							   SemanticProperties.Description="{loc:Loc views.shell.control_deck_view.log_file}" />
						<Button Grid.Column="2"
								Text="{loc:Loc views.shell.control_deck_view.log_open}"
								Command="{Binding OpenFullLogCommand, Source={x:Reference ControlDeckRoot}}"
								Style="{StaticResource HudMiniButtonStyle}"
								SemanticProperties.Description="{loc:Loc views.shell.control_deck_view.log_open}"
								SemanticProperties.Hint="{loc:Loc views.shell.control_deck_view.log_file_help}"
								TextColor="{StaticResource DeckAccentColor}" />
						<Button Grid.Column="3"
								Text="CLEAR"
								Command="{Binding ClearLogCommand, Source={x:Reference ControlDeckRoot}}"
								Style="{StaticResource HudMiniButtonStyle}"
								SemanticProperties.Description="{loc:Loc views.shell.control_deck_view.clear}"
								SemanticProperties.Hint="{loc:Loc views.shell.control_deck_view.clear_help}"
								TextColor="{StaticResource DeckDangerColor}"
								/>
					</Grid>
				</Border>

				<Border Grid.Row="1"
						Margin="10,8,10,6"
						Padding="10,0"
						BackgroundColor="{StaticResource DeckSearchColor}"
						Stroke="{StaticResource DeckStrokeColor}"
						StrokeThickness="1">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="6" />
					</Border.StrokeShape>
					<Entry x:Name="LogSearchEntry"
						   Placeholder="Filter logs"
						   PlaceholderColor="{StaticResource DeckPlaceholderColor}"
						   TextColor="{StaticResource DeckSearchTextColor}"
						   FontSize="12"
						   ClearButtonVisibility="WhileEditing"
						   TextChanged="OnLogSearchChanged" />
				</Border>

				<components:LogTailView x:Name="ConsoleLogTail"
										Grid.Row="2"
										Margin="10,0,10,8"
										MaxRows="{x:Static config:LogOptions.MaxRenderedRows}"
										PrewarmRows="50"
										MaxFlushBatchSize="50" />
			</Grid>
			</Grid>
		</Grid>
	</Border>
</ContentView>
