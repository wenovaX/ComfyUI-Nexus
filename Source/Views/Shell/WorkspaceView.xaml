<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 x:Class="ComfyUI_Nexus.Views.WorkspaceView">
	<ContentView.Resources>
		<Color x:Key="WorkspaceShellColor">#0b121c</Color>
		<Color x:Key="WorkspaceAccentColor">#00e5ff</Color>
		<Color x:Key="WorkspaceVioletColor">#7b61ff</Color>
		<Color x:Key="WorkspacePinkColor">#ff82b2</Color>
		<Color x:Key="WorkspaceBlueColor">#5fa4ff</Color>
	</ContentView.Resources>

	<Grid x:Name="WorkspaceChromeGrid"
		  RowDefinitions="*"
		  ColumnDefinitions="60,*"
		  RowSpacing="0"
		  ColumnSpacing="0"
		  BackgroundColor="{StaticResource WorkspaceShellColor}">
		<Border x:Name="CanvasFrameBorder"
				Grid.Row="0"
				Grid.Column="0"
				Grid.ColumnSpan="2"
				StrokeThickness="0"
				Stroke="Transparent"
				StrokeShape="Rectangle"
				BackgroundColor="Transparent">
			<Border.Shadow>
				<Shadow x:Name="CanvasFrameShadow"
						Brush="{StaticResource WorkspaceAccentColor}"
						Offset="0,0"
						Radius="0"
						Opacity="0" />
			</Border.Shadow>

			<ContentView BackgroundColor="{StaticResource WorkspaceShellColor}">
				<WebView x:Name="ComfyWebView"
						 HorizontalOptions="Fill"
						 VerticalOptions="Fill"
						 BackgroundColor="{StaticResource WorkspaceShellColor}"
						 Navigated="OnWebViewNavigated" />
			</ContentView>
		</Border>
	</Grid>
</ContentView>
